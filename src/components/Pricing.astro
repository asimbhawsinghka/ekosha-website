---
const APP_URL = 'https://app.ekosha.co.in';

const freeFeatures = [
  'Up to 5 assets',
  'Bank & insurance types',
  'Share with 1 person',
  '1 nominee',
  'Android & Web access',
  'AES-256 encryption',
];

const premiumFeatures = [
  'Unlimited assets',
  'All asset types',
  'Unlimited sharing',
  'Unlimited nominees',
  'Inheritance allocation',
  'Portfolio insights',
  'Document attachments',
  'Priority support',
];
---
<section id="pricing" class="bg-brand-bg py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-brand-navy mb-4">
        Simple, Honest Pricing
      </h2>
      <p class="text-brand-muted max-w-xl mx-auto text-lg">
        Start free. Upgrade when you need more. No hidden fees.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">

      <!-- Free plan -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-200">
        <h3 class="text-lg font-semibold text-brand-navy mb-1">Free</h3>
        <p class="text-brand-muted text-sm mb-6">For individuals getting started</p>
        <div class="mb-8">
          <span class="text-4xl font-bold text-brand-navy">₹0</span>
          <span class="text-brand-muted text-sm ml-1">/ forever</span>
        </div>
        <ul class="space-y-3 mb-8 text-sm text-brand-text">
          {freeFeatures.map(f => (
            <li class="flex items-center gap-2">
              <span class="text-brand-gold font-bold">✓</span> {f}
            </li>
          ))}
        </ul>
        <a
          href={APP_URL}
          class="block w-full text-center border-2 border-brand-navy text-brand-navy font-semibold py-3 rounded-xl hover:bg-brand-navy hover:text-white transition-all duration-150"
        >
          Get Started Free
        </a>
      </div>

      <!-- Premium plan -->
      <div class="relative bg-brand-navy rounded-2xl p-8 shadow-xl ring-2 ring-brand-gold">
        <!-- Most Popular badge -->
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
          <span class="bg-brand-gold text-white text-xs font-semibold px-4 py-1.5 rounded-full shadow-lg whitespace-nowrap">
            Most Popular
          </span>
        </div>

        <h3 class="text-lg font-semibold text-white mb-1">Premium</h3>
        <p class="text-white/60 text-sm mb-6">For families who need everything</p>
        <div class="mb-8">
          <span class="text-4xl font-bold text-white">₹199</span>
          <span class="text-white/60 text-sm ml-1">/ month</span>
        </div>
        <ul class="space-y-3 mb-8 text-sm text-white/80">
          {premiumFeatures.map(f => (
            <li class="flex items-center gap-2">
              <span class="text-brand-gold font-bold">✓</span> {f}
            </li>
          ))}
        </ul>
        <a
          href={APP_URL}
          class="block w-full text-center bg-brand-gold text-white font-semibold py-3 rounded-xl hover:bg-opacity-90 transition-all duration-150 shadow-lg"
        >
          Start Premium Trial
        </a>
      </div>

    </div>
  </div>
</section>
