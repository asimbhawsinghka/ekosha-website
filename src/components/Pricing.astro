---
const APP_URL = 'https://app.ekosha.co.in';

const freeFeatures = [
  'Up to 5 assets (any type)',
  '1 share (nominees, co-owners & explicit shares)',
  'Android & Web access',
  'AES-256 encryption',
];

const premiumFeatures = [
  'Up to 50 assets (any type)',
  'Up to 10 shares (nominees, co-owners & explicit shares)',
  'All asset types',
  'Priority support',
];
---
<section id="pricing" class="bg-brand-bg py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-5">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-navy mb-4 tracking-tight">
        Simple, Honest Pricing
      </h2>
      <p class="text-brand-muted max-w-xl mx-auto text-lg">
        Start free. Upgrade when you need more. No hidden fees.
      </p>
    </div>
    <!-- Gold rule -->
    <div class="flex justify-center mb-14">
      <div class="w-14 h-1 bg-brand-gold rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">

      <!-- Free plan -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-brand-navy/10">
        <h3 class="text-lg font-bold text-brand-navy mb-1">Free</h3>
        <p class="text-brand-muted text-sm mb-6">For individuals getting started</p>
        <div class="mb-8">
          <span class="text-4xl font-extrabold text-brand-navy">₹0</span>
          <span class="text-brand-muted text-sm ml-1">/ forever</span>
        </div>
        <ul class="space-y-3 mb-8 text-sm text-brand-text">
          {freeFeatures.map(f => (
            <li class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
        <a
          href={APP_URL}
          class="block w-full text-center border-2 border-brand-navy text-brand-navy font-semibold py-3 rounded-xl hover:bg-brand-navy hover:text-white transition-all duration-150"
        >
          Get Started Free
        </a>
      </div>

      <!-- Premium plan -->
      <div class="relative bg-brand-navy rounded-2xl shadow-xl border border-brand-gold/25 overflow-hidden">
        <!-- Gold top accent -->
        <div class="h-1.5 bg-brand-gold rounded-t-2xl"></div>

        <!-- Most Popular badge -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 translate-y-2">
          <span class="bg-brand-gold text-brand-navy text-xs font-bold px-4 py-1.5 rounded-full shadow-lg whitespace-nowrap">
            Most Popular
          </span>
        </div>

        <div class="px-8 pb-8 pt-8">
          <h3 class="text-lg font-bold text-white mb-1">eKosha Premium</h3>
          <p class="text-white/55 text-sm mb-4">For families who need everything</p>

          <!-- Monthly / Annual toggle -->
          <div class="flex items-center gap-1 bg-white/10 rounded-full p-1 mb-6 w-fit">
            <button
              id="pricing-monthly-btn"
              class="pricing-toggle-btn text-xs font-semibold px-4 py-1.5 rounded-full transition-all duration-150 bg-brand-gold text-brand-navy"
            >
              Monthly
            </button>
            <button
              id="pricing-annual-btn"
              class="pricing-toggle-btn text-xs font-semibold px-4 py-1.5 rounded-full transition-all duration-150 text-white/70"
            >
              Annual
            </button>
          </div>

          <!-- Monthly price -->
          <div id="pricing-monthly" class="mb-2">
            <span class="text-4xl font-extrabold text-white">₹99</span>
            <span class="text-white/55 text-sm ml-1">/ month</span>
          </div>

          <!-- Annual price -->
          <div id="pricing-annual" class="mb-2 hidden">
            <span class="text-4xl font-extrabold text-white">₹899</span>
            <span class="text-white/55 text-sm ml-1">/ year</span>
            <span class="ml-2 text-xs font-semibold bg-brand-gold/20 text-brand-gold px-2 py-0.5 rounded-full">Save ₹289</span>
          </div>

          <p class="text-white/40 text-xs mb-8">7-day free trial · cancel anytime</p>

          <ul class="space-y-3 mb-8 text-sm text-white/75">
            {premiumFeatures.map(f => (
              <li class="flex items-center gap-2.5">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a
            href={APP_URL}
            class="block w-full text-center bg-brand-gold text-brand-navy font-bold py-3 rounded-xl hover:bg-opacity-90 transition-all duration-150 shadow-lg"
          >
            Start 7-Day Free Trial
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const monthlyBtn = document.getElementById('pricing-monthly-btn');
  const annualBtn = document.getElementById('pricing-annual-btn');
  const monthlyPrice = document.getElementById('pricing-monthly');
  const annualPrice = document.getElementById('pricing-annual');

  const activeClass = ['bg-brand-gold', 'text-brand-navy'];
  const inactiveClass = ['text-white/70'];

  function setMonthly() {
    monthlyPrice?.classList.remove('hidden');
    annualPrice?.classList.add('hidden');
    monthlyBtn?.classList.add(...activeClass);
    monthlyBtn?.classList.remove(...inactiveClass);
    annualBtn?.classList.remove(...activeClass);
    annualBtn?.classList.add(...inactiveClass);
  }

  function setAnnual() {
    annualPrice?.classList.remove('hidden');
    monthlyPrice?.classList.add('hidden');
    annualBtn?.classList.add(...activeClass);
    annualBtn?.classList.remove(...inactiveClass);
    monthlyBtn?.classList.remove(...activeClass);
    monthlyBtn?.classList.add(...inactiveClass);
  }

  monthlyBtn?.addEventListener('click', setMonthly);
  annualBtn?.addEventListener('click', setAnnual);
</script>
