---
const features = [
  {
    icon: '🏦',
    title: 'Secure Asset Vault',
    body: 'Store bank accounts, FDs, PPF, and all financial assets in one private, encrypted place.',
    badge: 'bg-brand-navy',
  },
  {
    icon: '🤝',
    title: 'Trusted Sharing',
    body: 'Securely share specific assets or your full vault with trusted family members — with granular access controls.',
    badge: 'bg-brand-gold/20 border border-brand-gold/30',
  },
  {
    icon: '📋',
    title: 'Nominee Planning',
    body: 'Assign nominees to each asset and ensure the right people always know what they\'ll inherit.',
    badge: 'bg-brand-navy',
  },
  {
    icon: '📊',
    title: 'Portfolio Insights',
    body: 'See your complete family wealth at a glance — by asset type, institution, or nominee.',
    badge: 'bg-brand-gold/20 border border-brand-gold/30',
  },
  {
    icon: '🔐',
    title: 'End-to-End Encryption',
    body: 'AES-256 encryption means only you and those you authorise can ever read your data — not even us.',
    badge: 'bg-brand-navy',
  },
  {
    icon: '📱',
    title: 'Mobile + Web',
    body: 'Available as a native Android app and a full-featured web app — always in sync, always available.',
    badge: 'bg-brand-gold/20 border border-brand-gold/30',
  },
];
---
<section id="features" class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-5">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-navy mb-4 tracking-tight">
        Everything Your Family Needs
      </h2>
      <p class="text-brand-muted max-w-2xl mx-auto text-lg">
        eKosha is purpose-built for Indian families — supporting every asset type
        that matters across generations.
      </p>
    </div>
    <!-- Gold rule -->
    <div class="flex justify-center mb-14">
      <div class="w-14 h-1 bg-brand-gold rounded-full"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map(f => (
        <div class="rounded-2xl p-6 bg-white border border-brand-navy/10 shadow-sm hover:shadow-md hover:border-brand-gold/40 transition-all duration-200">
          <div class={`w-12 h-12 rounded-xl ${f.badge} flex items-center justify-center mb-5 text-xl`}>
            {f.icon}
          </div>
          <h3 class="text-lg font-bold text-brand-navy mb-2">{f.title}</h3>
          <p class="text-brand-muted text-sm leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
