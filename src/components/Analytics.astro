---
// PostHog product analytics — privacy-first config.
// Uses PostHog's own CDN snippet (is:inline) so Rollup never tries to bundle
// posthog-js, avoiding the "cannot resolve dynamic import" build error.
// Rendered only when PUBLIC_POSTHOG_KEY is set at build time.
const phKey = import.meta.env.PUBLIC_POSTHOG_KEY ?? '';
// Route through Netlify reverse proxy so ad blockers can't intercept PostHog traffic.
// Falls back to direct EU endpoint for local dev where /ingest/* isn't proxied.
const phHost = import.meta.env.PUBLIC_POSTHOG_HOST ?? (phKey ? '/ingest' : 'https://eu.i.posthog.com');
---
{phKey && (
  <script is:inline define:vars={{ phKey, phHost }}>
    /* eslint-disable -- PostHog's official minified snippet is intentionally ES5 */
    !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString()+" (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);

    posthog.init(phKey, {
      api_host: phHost,
      // localStorage+cookie so the anonymous id is stored in a cookie scoped to
      // the root domain (.ekosha.co.in) and shared with the app at
      // app.ekosha.co.in — this is what links the website -> app journey.
      persistence: 'localStorage+cookie',
      cross_subdomain_cookie: true,
      person_profiles: 'identified_only',
      respect_dnt: true,
      // Minimal footprint in the shared PROD project: only $pageview + the
      // explicit events below. Can flip to true later for heatmaps.
      autocapture: false,
      capture_pageview: true,
      disable_session_recording: true,
      disable_surveys: true,
    });

    // Label every event so website activity is distinguishable from the app's
    // surfaces within the shared PROD project. Two orthogonal axes, matching the
    // app: surface = product area, platform = runtime. Website is always web.
    posthog.register({ surface: 'marketing-website', platform: 'web' });

    document.addEventListener('click', function(event) {
      if (!(event.target instanceof Element)) return;

      var cta = event.target.closest('[data-cta]');
      if (cta) {
        posthog.capture('cta_click', {
          cta: cta.getAttribute('data-cta'),
          href: cta.getAttribute('href'),
          path: window.location.pathname,
        });
        return;
      }

      var toggle = event.target.closest('.pricing-toggle-btn');
      if (toggle) {
        posthog.capture('pricing_billing_toggle', {
          plan: toggle.id === 'pricing-annual-btn' ? 'annual' : 'monthly',
        });
      }
    });

    // Newsletter (Netlify Forms) sign-up — capture intent before the POST navigates.
    document.addEventListener('submit', function(event) {
      if (event.target instanceof Element && event.target.closest('[data-newsletter-form]')) {
        posthog.capture('newsletter_signup', { path: window.location.pathname });
      }
    });
  </script>
)}
