---
const securityCards = [
  { icon: '🔐', title: 'AES-256 Encryption', body: 'Your vault data is encrypted with AES-256 at rest — the same standard used by banks.' },
  { icon: '🔑', title: 'PBKDF2 Key Derivation', body: 'Encryption keys are derived from your credentials using PBKDF2 — never stored in plain text.' },
  { icon: '🧅', title: 'Two-layer Key Design', body: 'A vault key encrypts your data; a separate key encrypts the vault key — double protection.' },
  { icon: '☁️', title: 'Firebase Infrastructure', body: 'Backed by Google Firebase, certified to ISO 27001, SOC 2, and multiple global standards.' },
  { icon: '🙈', title: 'We Cannot Read Your Data', body: 'Zero-knowledge design means eKosha staff can never access your decrypted vault contents.' },
  { icon: '🔏', title: 'PIN & Biometric Lock', body: 'Every app session requires your PIN or biometric — even if someone unlocks your phone.' },
];
---
<section id="security" class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: trust content -->
      <div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-navy mb-3 tracking-tight">
          Built with the same standards as enterprise banking.
        </h2>
        <!-- Gold rule — left-aligned -->
        <div class="w-14 h-1 bg-brand-gold rounded-full mb-6"></div>
        <p class="text-brand-muted text-lg leading-relaxed mb-8">
          Your family's financial data is among the most sensitive information you own.
          We built eKosha with the same security standards used by leading financial
          institutions — so you can trust us with what matters most.
        </p>

        <!-- Trust badges — brand palette -->
        <div class="flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-2 bg-brand-navy/8 text-brand-navy text-sm font-semibold px-4 py-2 rounded-full border border-brand-navy/15">
            <svg class="w-3.5 h-3.5 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            AES-256 Encrypted
          </span>
          <span class="inline-flex items-center gap-2 bg-brand-gold/10 text-brand-navy text-sm font-semibold px-4 py-2 rounded-full border border-brand-gold/25">
            <svg class="w-3.5 h-3.5 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Firebase Certified
          </span>
          <span class="inline-flex items-center gap-2 bg-brand-navy/8 text-brand-navy text-sm font-semibold px-4 py-2 rounded-full border border-brand-navy/15">
            <svg class="w-3.5 h-3.5 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Zero-knowledge Design
          </span>
        </div>
      </div>

      <!-- Right: 2×3 security cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {securityCards.map(card => (
          <div class="bg-brand-bg rounded-xl p-5 border border-brand-navy/8">
            <div class="text-2xl mb-3">{card.icon}</div>
            <h4 class="font-bold text-brand-navy text-sm mb-1">{card.title}</h4>
            <p class="text-brand-muted text-xs leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
