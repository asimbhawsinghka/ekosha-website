---
const APP_URL = 'https://app.ekosha.co.in';
---
<section
  class="relative overflow-hidden"
  style="background: radial-gradient(ellipse at 72% 38%, #0D3B66 0%, #0E2240 62%);"
>
  <!-- Subtle grid overlay -->
  <div class="absolute inset-0 opacity-[0.07]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-grid" width="48" height="48" patternUnits="userSpaceOnUse">
          <path d="M 48 0 L 0 0 0 48" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)"/>
    </svg>
  </div>

  <!-- Gold accent glow top-right -->
  <div
    class="absolute -top-32 -right-32 w-96 h-96 rounded-full opacity-[0.06]"
    style="background: radial-gradient(circle, #E0B341 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 bg-white/8 text-white text-xs font-semibold px-3.5 py-1.5 rounded-full mb-7 border border-brand-gold/30">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-gold inline-block"></span>
          Private · Encrypted · Family-first
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 tracking-tight">
          Your family's financial safety net —{' '}
          <span class="text-brand-gold">organised and secure.</span>
        </h1>

        <p class="text-lg text-white/65 leading-relaxed mb-9 max-w-lg">
          eKosha is a private, encrypted place for Indian families to organise the
          financial information they depend on — bank accounts, FDs, mutual funds,
          property, insurance and nominee details — and share it with the people they
          trust, so nothing important is lost when it matters most.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <a
            href="/invite"
            data-cta="hero_get_started"
            class="inline-flex items-center justify-center bg-brand-gold text-brand-navy font-bold px-7 py-3.5 rounded-xl hover:bg-opacity-90 transition-all shadow-lg text-base"
          >
            Get Started — it's free
          </a>
          <a
            href={APP_URL}
            data-cta="hero_login"
            class="inline-flex items-center justify-center border border-white/25 text-white font-medium px-7 py-3.5 rounded-xl hover:bg-white/8 transition-all text-base"
          >
            Log In
          </a>
        </div>

        <!-- Fine print -->
        <p class="text-xs text-white/35">
          No credit card required · Free plan available · Android &amp; Web
        </p>
      </div>

      <!-- Right: card mockup (hidden on mobile) -->
      <div class="hidden lg:flex justify-center lg:justify-end">
        <div class="w-80 bg-white rounded-2xl shadow-2xl overflow-hidden border border-white/10">
          <!-- Card header — gradient navy -->
          <div class="px-5 py-4" style="background: linear-gradient(135deg, #0D3B66 0%, #0E2240 100%);">
            <p class="text-white/55 text-xs font-medium mb-1 uppercase tracking-wide">My Assets</p>
            <p class="text-white text-2xl font-extrabold tracking-tight">₹42,80,000</p>
            <p class="text-brand-gold text-xs font-semibold mt-0.5">Total Portfolio Value</p>
          </div>

          <!-- Asset rows -->
          <div class="px-5 py-4 space-y-3">
            <!-- Row 1 -->
            <div class="flex items-center justify-between py-2 border-b border-brand-bg">
              <div class="flex items-center gap-3">
                <span class="text-xl">🏦</span>
                <div>
                  <p class="text-sm font-semibold text-brand-text">SBI Savings Account</p>
                  <p class="text-xs text-brand-muted">Bank Account</p>
                </div>
              </div>
              <p class="text-sm font-bold text-brand-navy">₹3,40,000</p>
            </div>
            <!-- Row 2 -->
            <div class="flex items-center justify-between py-2 border-b border-brand-bg">
              <div class="flex items-center gap-3">
                <span class="text-xl">📈</span>
                <div>
                  <p class="text-sm font-semibold text-brand-text">LIC Life Insurance</p>
                  <p class="text-xs text-brand-muted">Insurance</p>
                </div>
              </div>
              <p class="text-sm font-bold text-brand-navy">₹9,40,000</p>
            </div>
            <!-- Row 3 -->
            <div class="flex items-center justify-between py-2">
              <div class="flex items-center gap-3">
                <span class="text-xl">💹</span>
                <div>
                  <p class="text-sm font-semibold text-brand-text">HDFC Equity Mutual Fund</p>
                  <p class="text-xs text-brand-muted">Mutual Fund</p>
                </div>
              </div>
              <p class="text-sm font-bold text-brand-navy">₹30,00,000</p>
            </div>
          </div>

          <!-- Encrypted footer badge — brand-palette -->
          <div class="bg-brand-bg border-t border-brand-navy/10 px-5 py-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            <span class="text-xs font-semibold text-brand-navy">AES-256 encrypted · Only you hold the keys</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
