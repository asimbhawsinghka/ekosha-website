---
const APP_URL = 'https://app.ekosha.co.in';
const year = new Date().getFullYear();
---
<footer class="bg-brand-navy">

  <!-- CTA band -->
  <div class="border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Start building your family's financial safety net today.
      </h2>
      <p class="text-white/60 text-lg mb-8 max-w-xl mx-auto">
        Join thousands of Indian families who trust eKosha to protect and pass on
        their wealth.
      </p>
      <a
        href={APP_URL}
        class="inline-flex items-center justify-center bg-brand-gold text-white font-semibold px-8 py-4 rounded-xl text-base hover:bg-opacity-90 transition-all shadow-lg"
      >
        Get Started Free
      </a>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5">
        <svg width="35" height="28" viewBox="0 0 44 36" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <clipPath id="footer-circle-clip">
              <circle cx="17" cy="19" r="14.5"/>
            </clipPath>
          </defs>
          <circle cx="17" cy="19" r="14.5" fill="white" fill-opacity="0.12"/>
          <g clip-path="url(#footer-circle-clip)">
            <rect x="15.2" y="27" width="3.6" height="8" rx="1.8" fill="#C9A227"/>
            <ellipse cx="17" cy="13" rx="3.2" ry="5.5" fill="#C9A227"/>
            <ellipse cx="10.5" cy="16.5" rx="3.2" ry="5.5" fill="#C9A227" transform="rotate(-40 10.5 16.5)"/>
            <ellipse cx="23.5" cy="16.5" rx="3.2" ry="5.5" fill="#C9A227" transform="rotate(40 23.5 16.5)"/>
            <ellipse cx="6.5" cy="22" rx="3.2" ry="5.5" fill="#C9A227" transform="rotate(-28 6.5 22)"/>
            <ellipse cx="27.5" cy="22" rx="3.2" ry="5.5" fill="#C9A227" transform="rotate(28 27.5 22)"/>
            <ellipse cx="10.5" cy="26.5" rx="3.2" ry="5.5" fill="#C9A227" transform="rotate(-12 10.5 26.5)"/>
            <ellipse cx="23.5" cy="26.5" rx="3.2" ry="5.5" fill="#C9A227" transform="rotate(12 23.5 26.5)"/>
          </g>
          <circle cx="17" cy="19" r="14.5" fill="none" stroke="white" stroke-opacity="0.9" stroke-width="2.4"/>
          <line x1="29.5" y1="10" x2="43" y2="10" stroke="white" stroke-opacity="0.9" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="30.5" y1="14.5" x2="43" y2="14.5" stroke="white" stroke-opacity="0.9" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
        <span class="text-lg font-bold text-white">eKosha</span>
      </a>

      <!-- Links -->
      <nav class="flex items-center gap-6 text-sm text-white/60">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="mailto:support@ekosha.co.in" class="hover:text-white transition-colors">
          support@ekosha.co.in
        </a>
      </nav>

      <!-- Copyright -->
      <p class="text-white/40 text-xs">
        &copy; {year} eKosha. All rights reserved.
      </p>

    </div>
  </div>

</footer>
