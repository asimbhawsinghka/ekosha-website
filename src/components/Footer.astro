---
const APP_URL = 'https://app.ekosha.co.in';
const year = new Date().getFullYear();
---
<footer class="bg-brand-navy">

  <!-- CTA band -->
  <div class="border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Start building your family's financial safety net today.
      </h2>
      <p class="text-white/60 text-lg mb-8 max-w-xl mx-auto">
        Join thousands of Indian families who trust eKosha to protect and pass on
        their wealth.
      </p>
      <a
        href={APP_URL}
        class="inline-flex items-center justify-center bg-brand-teal text-white font-semibold px-8 py-4 rounded-xl text-base hover:bg-opacity-90 transition-all shadow-lg"
      >
        Get Started Free
      </a>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <svg width="28" height="28" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
          <rect width="64" height="64" rx="12" fill="white" fill-opacity="0.15"/>
          <path d="M32 10 L50 18 L50 34 C50 44 41 52 32 56 C23 52 14 44 14 34 L14 18 Z" fill="#00A896"/>
          <polyline points="22,32 29,40 42,25" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="text-lg font-bold text-white">eKosha</span>
      </a>

      <!-- Links -->
      <nav class="flex items-center gap-6 text-sm text-white/60">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="mailto:support@ekosha.co.in" class="hover:text-white transition-colors">
          support@ekosha.co.in
        </a>
      </nav>

      <!-- Copyright -->
      <p class="text-white/40 text-xs">
        &copy; {year} eKosha. All rights reserved.
      </p>

    </div>
  </div>

</footer>
