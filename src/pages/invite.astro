---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const APP_URL = 'https://app.ekosha.co.in';
const PLAY_STORE_URL = 'https://play.google.com/store/apps/details?id=com.ekosha.app';
// TODO: flip to true once the Play Store listing for com.ekosha.app is public,
// and swap the disabled badge below for the <a href={PLAY_STORE_URL}> branch.
const PLAY_STORE_LIVE = false;
// TODO: flip to true once an iOS app + App Store listing exist, and add the
// real store URL alongside this flag.
const APP_STORE_LIVE = false;
---

<Layout
  title="Get the eKosha App — eKosha"
  description="Download eKosha, the private encrypted vault for Indian families to store, organise and share financial assets."
>
  <Nav />
  <main class="bg-brand-bg min-h-screen">
    <div class="max-w-2xl mx-auto px-6 py-24 text-center">

      <img src="/images/logo.png" alt="eKosha" class="h-16 w-16 mx-auto rounded-2xl shadow-md mb-6" />

      <h1 class="text-3xl sm:text-4xl font-bold text-brand-navy mb-3">Get the eKosha App</h1>
      <p class="text-brand-muted text-lg mb-12 max-w-md mx-auto">
        Your family's financial vault — encrypted, organised, and easy to share.
      </p>

      <!-- Store badges + web fallback — hidden on iOS in favour of the Add to Home Screen instructions below -->
      <div id="store-badges">
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        {PLAY_STORE_LIVE ? (
          <a
            href={PLAY_STORE_URL}
            data-cta="invite_play_store"
            class="flex items-center gap-3 bg-brand-navy text-white rounded-xl px-6 py-3.5 hover:bg-opacity-90 transition-all shadow-lg"
          >
            <svg class="w-7 h-7 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-8m0 8l-3.5-3.5M12 16l3.5-3.5M4 20h16" />
            </svg>
            <span class="text-left">
              <span class="block text-[10px] uppercase tracking-wide text-white/60">Get it on</span>
              <span class="block text-base font-semibold leading-tight">Google Play</span>
            </span>
          </a>
        ) : (
          <span
            aria-disabled="true"
            class="flex items-center gap-3 bg-white text-brand-muted border border-brand-muted/20 rounded-xl px-6 py-3.5 opacity-60 cursor-not-allowed"
          >
            <svg class="w-7 h-7 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-8m0 8l-3.5-3.5M12 16l3.5-3.5M4 20h16" />
            </svg>
            <span class="text-left">
              <span class="block text-[10px] uppercase tracking-wide">Coming soon on</span>
              <span class="block text-base font-semibold leading-tight">Google Play</span>
            </span>
          </span>
        )}

        {APP_STORE_LIVE ? (
          <a
            href="#"
            data-cta="invite_app_store"
            class="flex items-center gap-3 bg-brand-navy text-white rounded-xl px-6 py-3.5 hover:bg-opacity-90 transition-all shadow-lg"
          >
            <svg class="w-7 h-7 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-8m0 8l-3.5-3.5M12 16l3.5-3.5M4 20h16" />
            </svg>
            <span class="text-left">
              <span class="block text-[10px] uppercase tracking-wide text-white/60">Get it on</span>
              <span class="block text-base font-semibold leading-tight">App Store</span>
            </span>
          </a>
        ) : (
          <span
            aria-disabled="true"
            class="flex items-center gap-3 bg-white text-brand-muted border border-brand-muted/20 rounded-xl px-6 py-3.5 opacity-60 cursor-not-allowed"
          >
            <svg class="w-7 h-7 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-8m0 8l-3.5-3.5M12 16l3.5-3.5M4 20h16" />
            </svg>
            <span class="text-left">
              <span class="block text-[10px] uppercase tracking-wide">Coming soon on</span>
              <span class="block text-base font-semibold leading-tight">App Store</span>
            </span>
          </span>
        )}
      </div>

      <p class="text-brand-muted text-sm mb-3">Or continue using eKosha on the web</p>
      <a
        href={APP_URL}
        data-cta="invite_continue_web"
        class="inline-flex items-center justify-center bg-brand-gold text-brand-navy font-semibold px-6 py-3 rounded-xl hover:bg-opacity-90 transition-all"
      >
        Continue to eKosha Web App
      </a>
      </div>

      <!-- iOS instructions — shown instead of the badges above on iOS, where neither store link is actionable -->
      <div id="ios-instructions" class="hidden text-left bg-white rounded-2xl border border-brand-muted/15 shadow-sm p-8 max-w-md mx-auto">
        <h2 class="text-xl font-bold text-brand-navy mb-2">Install eKosha on your iPhone</h2>
        <p class="text-brand-muted text-sm mb-6">
          eKosha works as an installable web app on iOS. Open it in Safari, then add it to your Home Screen:
        </p>
        <ol class="space-y-4 mb-6">
          <li class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-brand-navy text-white text-xs font-bold flex items-center justify-center">1</span>
            <span class="text-sm text-brand-text pt-0.5">
              Open <strong>app.ekosha.co.in</strong> in Safari.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-brand-navy text-white text-xs font-bold flex items-center justify-center">2</span>
            <span class="text-sm text-brand-text pt-0.5 flex items-center gap-2 flex-wrap">
              Tap the Share icon
              <svg class="w-5 h-5 text-brand-navy shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16V4m0 0L8 8m4-4l4 4M5 14v4a2 2 0 002 2h10a2 2 0 002-2v-4" />
              </svg>
              in the toolbar.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-brand-navy text-white text-xs font-bold flex items-center justify-center">3</span>
            <span class="text-sm text-brand-text pt-0.5">
              Scroll down and tap <strong>Add to Home Screen</strong>, then tap <strong>Add</strong>.
            </span>
          </li>
        </ol>
        <a
          href={APP_URL}
          data-cta="invite_ios_open_webapp"
          class="block w-full text-center bg-brand-gold text-brand-navy font-semibold py-3 rounded-xl hover:bg-opacity-90 transition-all"
        >
          Open eKosha in Safari
        </a>
      </div>

    </div>
  </main>
  <Footer />

  <script is:inline>
    // The token is for analytics attribution only — the backend's invite-acceptance
    // logic matches the recipient by email, so nothing here blocks or branches on it.
    const token = new URLSearchParams(window.location.search).get('token');
    if (token) sessionStorage.setItem('invite_token', token);

    if (/iPad|iPhone|iPod/.test(navigator.userAgent)) {
      document.getElementById('store-badges').classList.add('hidden');
      document.getElementById('ios-instructions').classList.remove('hidden');
    }
  </script>
</Layout>
