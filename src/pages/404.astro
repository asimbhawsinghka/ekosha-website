---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — eKosha" description="The page you're looking for doesn't exist." noindex={true}>
  <main class="min-h-screen bg-brand-navy flex flex-col items-center justify-center px-6 text-center">
    <div class="text-brand-teal text-8xl font-bold mb-4">404</div>
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Page not found</h1>
    <p class="text-brand-muted text-lg mb-8 max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-block bg-brand-teal text-white font-semibold px-8 py-3 rounded-lg hover:opacity-90 transition"
    >
      Back to home
    </a>
  </main>
</Layout>
