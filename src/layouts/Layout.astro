---
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = "eKosha — Your Family's Financial Safety Net, Organised & Secure",
  description = 'eKosha helps Indian families stay financially prepared — a private, encrypted place to organise the assets, nominees and financial information your family depends on, and share it with the people you trust.',
  image = '/og-image.png',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);

const siteURL = Astro.site?.toString().replace(/\/$/, '') ?? 'https://ekosha.co.in';

// Site-wide structured data. Kept as a @graph so Organization, WebSite and the
// app itself are cross-referenced. No ratings are fabricated.
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteURL}/#organization`,
      name: 'eKosha',
      url: `${siteURL}/`,
      logo: `${siteURL}/images/logo.png`,
      description:
        'eKosha helps Indian families stay financially prepared — a private, encrypted place to organise the assets, nominees and financial information a family depends on, and share it with the people they trust.',
    },
    {
      '@type': 'WebSite',
      '@id': `${siteURL}/#website`,
      url: `${siteURL}/`,
      name: 'eKosha',
      inLanguage: 'en-IN',
      publisher: { '@id': `${siteURL}/#organization` },
    },
    {
      '@type': 'SoftwareApplication',
      name: 'eKosha',
      operatingSystem: 'Android, Web',
      applicationCategory: 'FinanceApplication',
      url: 'https://app.ekosha.co.in',
      publisher: { '@id': `${siteURL}/#organization` },
      offers: [
        { '@type': 'Offer', name: 'Free', price: '0', priceCurrency: 'INR' },
        { '@type': 'Offer', name: 'Premium', price: '99', priceCurrency: 'INR' },
      ],
    },
  ],
};
---
<!doctype html>
<html lang="en-IN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="256x256" href="/images/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0E2240" />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="eKosha — help your family stay financially prepared" />
    <meta property="og:site_name" content="eKosha" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="eKosha — help your family stay financially prepared" />

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Product analytics (PostHog) -->
    <Analytics />
  </head>
  <body class="font-sans text-brand-text bg-white antialiased">
    <slot />
  </body>
</html>
